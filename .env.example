# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in real values.
# .env.local is server-only and git-ignored. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Bypasses RLS — never expose to the client bundle.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic Claude API (console.anthropic.com) — used from Slice 1 onward
ANTHROPIC_API_KEY=sk-ant-...

# MailerLite (Integrations → API) — used from Slice 3 onward
MAILERLITE_API_KEY=

# Sanity (sanity.io/manage → API) — used from Slice 5 onward
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_WRITE_TOKEN=

# DataForSEO (Basic Auth: email/password) — used from Slice 4 onward
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
