# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in real values.
# .env.local is server-only and git-ignored. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Bypasses RLS — never expose to the client bundle.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic Claude API (console.anthropic.com) — used from Slice 1 onward
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (aistudio.google.com → API keys) — AI hero images in emails
GEMINI_API_KEY=
# Optional per-tier model overrides (Settings → Visual identity picks the tier).
# Defaults: standard gemini-3.1-flash-image, lite gemini-3.1-flash-lite-image,
# pro gemini-3-pro-image
GEMINI_IMAGE_MODEL=
GEMINI_IMAGE_MODEL_LITE=
GEMINI_IMAGE_MODEL_PRO=

# MailerLite (Integrations → API) — used from Slice 3 onward
MAILERLITE_API_KEY=

# Sanity (sanity.io/manage → API) — blog publishing
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_WRITE_TOKEN=
# Optional: the studio document type blog posts are written as (default: post)
SANITY_POST_TYPE=

# Encryption key for publishing credentials saved in Settings → Connections
# (MailerLite API key, Sanity write token). 32 bytes, base64. Generate with:
#   openssl rand -base64 32
INTEGRATION_ENCRYPTION_KEY=

# DataForSEO (Basic Auth: email/password) — used from Slice 4 onward
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Recurring automation (Settings → Schedules). Authenticates Vercel Cron's
# daily tick at /api/cron/run-schedules. Generate any random string with:
#   openssl rand -hex 32
# and set the SAME value as a Vercel project env var.
CRON_SECRET=

# Optional cost brake: block new AI generation once the last 24h of estimated
# spend (the same numbers as the /logs page) crosses this many dollars.
# Unset or 0 = no cap. This is the HOUSE limit and stays in place alongside
# per-customer credits: it's the backstop if the credit meter is ever wrong.
DAILY_SPEND_LIMIT_USD=

# Billing (migration 019). Real call cost x this multiplier = credits charged,
# i.e. the margin. Only a FALLBACK: the live value is billing_config.
# markup_multiplier in the database, which can be tuned without a redeploy.
CREDIT_MARKUP_MULTIPLIER=2.0

# Stripe (billing slice 4+). Test-mode keys from the Stripe dashboard; leave
# unset and /billing degrades to "not set up yet" instead of crashing.
STRIPE_SECRET_KEY=
# From `stripe listen --forward-to localhost:3000/api/stripe/webhook` in dev,
# or the deployed webhook endpoint's signing secret in production.
STRIPE_WEBHOOK_SECRET=
#
# Credit packs are NOT env vars: they're rows in billing_config.packs (jsonb),
# e.g. [{"id":"pack_1000","credits":1000,"price_usd":10,"stripe_price_id":"price_..."}].
# Create a one-time Price per pack in the Stripe dashboard first, then update
# that row so /billing and /api/billing/checkout can see it.
#
# The pro subscription Price id (billing slice 5). A recurring monthly Price
# in the Stripe dashboard; read directly by POST /api/billing/checkout
# {"plan":"pro"}. Unset = the "Upgrade to Pro" button 503s with a clear error
# instead of creating a broken Checkout Session.
STRIPE_PRO_PRICE_ID=
#
# Monthly allowance cron (billing slice 5): CRON_SECRET above also gates
# /api/cron/grant-allowances (see vercel.json). Grants billing_config's
# free_monthly_allowance or paid_monthly_allowance to every brand whose
# credits_balance.last_allowance_period isn't the current month yet.
